local WORLD_LEVEL_RANGE = {
    [1] = {min=0,    max=2299},
    [2] = {min=2300, max=3999},
    [3] = {min=4000, max=99999},
}

local function refreshDailyQuests()
    AutoDailyS.quests = {}
    local currentWorld = getPlayerWorld()
    local range = WORLD_LEVEL_RANGE[currentWorld]

    for questName, questData in pairs(QuestManager) do
        if type(questData) == "table" and questData.DailyQuest == true then
            local hasMob     = questData.Mob ~= nil
            local hasHandler = DAILY_SPECIAL_HANDLERS[questName] ~= nil
            if hasMob or hasHandler then
                local questLevel = questData.Level or 0
                if questLevel >= range.min and questLevel <= range.max then
                    table.insert(AutoDailyS.quests, {
                        name   = questName,
                        mob    = questData.Mob,
                        amount = questData.Ammount or questData.Amount or 1,
                        level  = questLevel,
                    })
                end
            end
        end
    end
    table.sort(AutoDailyS.quests, function(a, b)
        return a.level < b.level
    end)

    WindUI:Notify({
        Title   = "Daily Quest",
        Content = "World "..currentWorld.." | Found "..#AutoDailyS.quests.." quests",
        Icon    = "scroll",
        Duration = 3
    })
end
