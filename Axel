-- ==================== Quest Functions ====================
local function getQuestDataForLevel(level)
    local bestQuest, bestLevel = nil, -1
    for questName, questData in pairs(QuestManager) do
        if type(questData) == "table" then
            local questLevel = questData.Level or 0
            local mob        = questData.Mob
            if questData.DailyQuest then continue end
            if SKIP_QUESTS[questName] then continue end
            if mob and questLevel <= level and questLevel > bestLevel then
                bestLevel = questLevel
                bestQuest = {
                    questName = questName, mob = mob,
                    questArgs = {"take", questName},
                    amount    = questData.Ammount or questData.Amount or 1
                }
            end
        end
    end
    return bestQuest
end

local function getBossQuestName(bossName)
    for questName, questData in pairs(QuestManager) do
        if type(questData) == "table" and questData.Mob then
            if questData.Mob == bossName then
                return questName, {"take", questName}
            end
        end
    end
    return nil, nil
end

function checklevel()
    local level = lp.PlayerStats.lvl.Value
    local data  = getQuestDataForLevel(level)
    if data then
        MON        = data.mob
        QUEST_ARGS = data.questArgs
        FOLDER     = (data.amount == 1) and "Boss" or "Mon"
    end
end
