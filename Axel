-- ==================== Auto Dodge Logic Loop ====================
 DODGE_RANGE = 80
 MIN_SPEED = 10
 DODGE_COOLDOWN = 0.1
 DODGE_DISTANCE = 80
 lastDodge = 0
 isDodging = false
 activeProjectiles = 0  

 PROJECTILE_NAMES = {}

 function buildProjectileNames()
    pcall(function()
         modulesFolder = RepStorage:FindFirstChild("Chest")
            and RepStorage.Chest:FindFirstChild("Assets")
            and RepStorage.Chest.Assets:FindFirstChild("Modules")
        if not modulesFolder then return end

         skillDataFolder = modulesFolder:FindFirstChild("SkillData")
        if not skillDataFolder then return end

        for _, folder in ipairs(skillDataFolder:GetDescendants()) do
            if folder:IsA("ModuleScript") then
                 ok, data = pcall(require, folder)
                if ok and type(data) == "table" then
                    for key, skillName in pairs(data) do
                        if type(skillName) == "string" and skillName ~= "" then
                             noSpace = skillName:gsub("%s+", "")
                            PROJECTILE_NAMES[noSpace] = true

                             firstWord = skillName:match("^(%S+)")
                            if firstWord then
                                PROJECTILE_NAMES[firstWord] = true
                            end
                        end
                    end
                end
            end
        end
    end)

     fallback = {
        ["BombBall"]=true, ["Trail"]=true, ["FlameBeam"]=true,
        ["Shockwave"]=true, ["Cloud"]=true, ["RumbleRing"]=true,
        ["IceFrozen"]=true, ["IcePath"]=true, ["FlameBall2"]=true,
        ["Swave"]=true, ["Rock"]=true, ["Shockowave"]=true,
        ["cartoon_smoke"]=true, ["puddle"]=true, ["Spike"]=true,
        ["Bullet"]=true, ["rock1"]=true, ["rock2"]=true,
        ['Beam']=true, ['ball']=true,['blackball'] = true, ['Cloud'] = true,
        ['RandomTrail'] = true, ['smoke'] = true,
    }
    for k, v in pairs(fallback) do
        PROJECTILE_NAMES[k] = v
    end

     count = 0
    for _ in pairs(PROJECTILE_NAMES) do count = count + 1 end
    print("[AutoDodge] Loaded "..count.." projectile names from SkillData")
end

buildProjectileNames()

local function dodgeAway(hrp, fromPos)
    if tick() - lastDodge < DODGE_COOLDOWN then return end
    if not (AutoS.dungeon or AutoS.dungeonV2) then return end
    if not AutoS.autoDodge then return end
    lastDodge = tick()
    isDodging = true

      awayDir = (hrp.Position - fromPos)
    if awayDir.Magnitude < 5 then
        awayDir = Vector3.new(math.random(-1,1), 0, math.random(-1,1))
    end
    awayDir = awayDir.Unit

     angle = math.rad(math.random(0, 315))
     rotated = CFrame.Angles(0, angle, 0):VectorToWorldSpace(awayDir)
     dodgePos = hrp.Position + rotated * DODGE_DISTANCE

    hrp.CFrame = CFrame.new(dodgePos, dodgePos + rotated)
end

workspace.Effects.ChildAdded:Connect(function(obj)
    if not AutoS.autoDodge then return end
    if not PROJECTILE_NAMES[obj.Name] then return end

    activeProjectiles = activeProjectiles + 1
    isDodging = true

    obj.AncestryChanged:Connect(function(_, parent)
        if parent == nil then
            activeProjectiles = math.max(0, activeProjectiles - 1)
            if activeProjectiles == 0 then
                task.delay(0.2, function()
                    if activeProjectiles == 0 then
                        isDodging = false
                    end
                end)
            end
        end
    end)

    task.spawn(function()
         startTime = tick()
         lastPos = nil

        while obj and obj.Parent and (tick() - startTime < 3) do
            task.wait(0.05)

            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then break end

            local ok, objPos = pcall(function()
                if obj:IsA("BasePart") then return obj.Position
                elseif obj:IsA("Model") then return obj:GetModelCFrame().Position end
            end)
            if not ok or not objPos then break end

            local dist = (objPos - hrp.Position).Magnitude

            if dist < 15 then
                dodgeAway(hrp, objPos)
                break
            end

            if dist > DODGE_RANGE then lastPos = objPos continue end

            if lastPos then
                local moveDir = (objPos - lastPos)
                if moveDir.Magnitude > 0 then
                    moveDir = moveDir.Unit
                     speed = (objPos - lastPos).Magnitude / 0.05
                     dot = moveDir:Dot((hrp.Position - objPos).Unit)

                    if dot > 0.4 and speed > MIN_SPEED then
                        dodgeAway(hrp, objPos)
                        break
                    end
                end
            end
            lastPos = objPos
        end
    end)
end)
