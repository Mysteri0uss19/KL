local skillDataCache = {}
local function getSkillCooldownTime(key)
    local cd = 1.0
    pcall(function()
        local weaponName = selectedWeapon
        if not weaponName or weaponName == "" or weaponName == "None" then return end

        local cachedData = skillDataCache[weaponName]
        if not cachedData then
            local modulesFolder = RepStorage:FindFirstChild("Chest") and
                RepStorage.Chest:FindFirstChild("Assets") and
                RepStorage.Chest.Assets:FindFirstChild("Modules")
            if not modulesFolder then return end

            local skillDataFolder = modulesFolder:FindFirstChild("SkillData")
            if not skillDataFolder then return end

            local function findSkillModule(name)
                for _, folder in ipairs(skillDataFolder:GetChildren()) do
                    local doubled = name .. name .. "_Data"
                    local simple  = name .. "_Data"
                    local mod = folder:FindFirstChild(name)
                               or folder:FindFirstChild(doubled)
                               or folder:FindFirstChild(simple)
                    if mod and mod:IsA("ModuleScript") then return mod end
                end
                for _, mod in ipairs(skillDataFolder:GetDescendants()) do
                    if mod:IsA("ModuleScript") and
                       (mod.Name == name or mod.Name == name.."_Data"
                         or mod.Name:find(name, 1, true)) then
                        return mod
                    end
                end
                return nil
            end

            local skillMod = findSkillModule(weaponName)
            if not skillMod then
                skillDataCache[weaponName] = {}  
                return
            end

            local ok, data = pcall(require, skillMod)
            if ok and type(data) == "table" then
                skillDataCache[weaponName] = data
                cachedData = data
            else
                skillDataCache[weaponName] = {}
                return
            end
        end

        local keyCd = cachedData[key]
        if type(keyCd) == "number" and keyCd > 0 then
            cd = keyCd + 0.2
        end
    end)
    return cd
end

