local function getAllEggs()
    local eggs = {}
    local effects = workspace:FindFirstChild("Effects")
    if not effects then return eggs end

    for _, v in pairs(effects:GetChildren()) do
        local nameLower = v.Name:lower()
        if nameLower:find("egg") then
            local filterOk = false

            if type(selectedEggFilter) == "string" then
                filterOk = (selectedEggFilter == "" or selectedEggFilter == "(All Eggs)" or v.Name == selectedEggFilter)
            
            elseif type(selectedEggFilter) == "table" then
                if #selectedEggFilter == 0 then
                    filterOk = true
                else
                    for _, sel in ipairs(selectedEggFilter) do
                        if sel == "(All Eggs)" or sel == v.Name then
                            filterOk = true
                            break
                        end
                    end
                    if not filterOk then
                        for k, val in pairs(selectedEggFilter) do
                            if val == true and (k == "(All Eggs)" or k == v.Name) then
                                filterOk = true
                                break
                            end
                        end
                    end
                end
            end

            if filterOk then
                local prompt = v:FindFirstChild("ProximityPrompt")
                    or v:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then
                    table.insert(eggs, {model = v, prompt = prompt})
                end
            end
        end
    end
    return eggs
end

local function hasEgg()
    return #getAllEggs() > 0
end

local visitedServers = {}
local function HopServer()
    local url = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
    local success, result = pcall(function()
        return game:GetService("HttpService"):JSONDecode(game:HttpGet(url))
    end)

    if not success or not result or not result.data then return end

    for _, server in ipairs(result.data) do
        if server.playing < server.maxPlayers 
        and server.id ~= game.JobId 
        and not visitedServers[server.id] then
            visitedServers[server.id] = true
            game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, server.id, lp)
            break
        end
    end
end

