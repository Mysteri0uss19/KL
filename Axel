local function getSeaFrame()
    local pg   = game:GetService("Players").LocalPlayer.PlayerGui
    local mainGui = pg:FindFirstChild("MainGui")
    if not mainGui then return nil, nil end
    local starterFrame = mainGui:FindFirstChild("StarterFrame")
    if not starterFrame then return nil, nil end
    local legacyPoseFrame = starterFrame:FindFirstChild("LegacyPoseFrame")
    if not legacyPoseFrame then return nil, nil end

    local RS = game:GetService("ReplicatedStorage")
    local v5 = require(RS.Chest.Modules.WorldsId)

    if game.PlaceId == v5.KingLegacy.SecondSea then
        return legacyPoseFrame:FindFirstChild("SecondSea"), "SecondSea"
    elseif game.PlaceId == v5.KingLegacy.ThirdSea then
        return legacyPoseFrame:FindFirstChild("ThirdSea"), "ThirdSea"
    end
    return nil, nil
end

local function collectInfo(frame)
    local descParts = {}
    local imageId   = ""

    for _, child in ipairs(frame:GetChildren()) do
        if child:IsA("TextLabel") and child.Text and child.Text ~= "" then
            table.insert(descParts, child.Text)
        end
        if child:IsA("ImageLabel") and child.Image and child.Image ~= "" and imageId == "" then
            imageId = child.Image
        end
    end

    return table.concat(descParts, " | "), imageId
end

