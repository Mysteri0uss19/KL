local function farmBossByName(bossName)
    local folder = workspace.Monster:FindFirstChild("Boss")
    if not folder then return end
    for _, mob in ipairs(folder:GetChildren()) do
        if mob.Name == bossName then
            local hum  = mob:FindFirstChildOfClass("Humanoid")
            local root = mob:FindFirstChild("HumanoidRootPart")
            if hum and root and hum.Health > 0 then
                if FarmS.method == "Above" then
                    tp(CFrame.lookAt(root.Position+Vector3.new(0,FarmS.aboveDist,0), root.Position))
                elseif FarmS.method == "Below" then
                    tp(CFrame.lookAt(root.Position-Vector3.new(0,FarmS.aboveDist,0), root.Position))
