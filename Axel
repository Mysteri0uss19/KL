local function getNearestHRP()
    local closest, shortestDistance = nil, math.huge
    local function checkFolder(folder)
        for _, obj in pairs(folder:GetChildren()) do
            if obj and obj:FindFirstChild("HumanoidRootPart") then
                local hrp = obj:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local distance = (myRoot.Position - hrp.Position).Magnitude
                    if distance < shortestDistance then shortestDistance=distance closest=hrp end
                end
            end
        end
    end
    checkFolder(folder1) checkFolder(folder2) checkFolder(folder3)
    return closest
end

local function fireSkill(key)
    if SkillS.firing[key] then return end
    local now  = tick()
    local last = SkillS.lastFire[key] or 0
    local cd   = getSkillCooldownTime(key)

    if now - last < cd then return end 

    SkillS.firing[key]  = true
    SkillS.lastFire[key] = now

    task.spawn(function()
        local nearestHRP
        local h = getNearestHRP()
        if h then nearestHRP = h.CFrame
        else
            local char = lp.Character
            nearestHRP = char and char:FindFirstChild("HumanoidRootPart") 
                         and char.HumanoidRootPart.CFrame or CFrame.new()
        end
        pcall(function()
            SkillRemote:InvokeServer(getSkillName(key), {MouseHit=nearestHRP, Type="Up"})
        end)
        task.wait(0.05)
        pcall(function()
            SkillRemote:InvokeServer(getSkillName(key), {MouseHit=nearestHRP, Type="Down"})
        end)

        SkillS.firing[key] = false
    end)
end

