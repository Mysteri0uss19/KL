                while _G.AutoPassiveTree do
                    local char=lp.Character
                    local root=char and char:FindFirstChild("HumanoidRootPart")
                    local curTgt=workspace.AllNPC:FindFirstChild("PassiveTree")
                    if root and curTgt then
                        local targetCF=curTgt:IsA("Model") and curTgt:GetModelCFrame() or curTgt.CFrame
                        root.CFrame=targetCF
                    end
                    task.wait(0.25)
                end
            end)
        end
    end
})

