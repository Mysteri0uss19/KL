local function refreshBossList()
    BossS.list = {}
    local bossFolder = workspace:FindFirstChild("Monster") and workspace.Monster:FindFirstChild("Boss")
    if bossFolder then
        local seen      = {}
        local bossLevel = {}
        for _, qd in pairs(QuestManager) do
            if type(qd) == "table" and qd.Mob then
                local m, l = qd.Mob, qd.Level or 0
                if not bossLevel[m] or l > bossLevel[m] then bossLevel[m] = l end
            end
        end
        local tmp = {}
        for _, mob in ipairs(bossFolder:GetDescendants()) do
            if not seen[mob.Name]
                and (mob:FindFirstChildOfClass("Humanoid") or mob:FindFirstChild("HumanoidRootPart"))
            then
                seen[mob.Name] = true
                table.insert(tmp, {name=mob.Name, level=bossLevel[mob.Name] or 0})
            end
        end
        table.sort(tmp, function(a,b) return a.level < b.level end)
        for _, v in ipairs(tmp) do table.insert(BossS.list, v.name) end
    end
    if #BossS.list == 0 then BossS.list = {"(No Boss Found)"} end
    if DS.boss then
        pcall(function() DS.boss.Values = BossS.list end)
        pcall(function() DS.boss:Refresh(BossS.list) end)
        pcall(function() DS.boss:Update() end)
    end
end
