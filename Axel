local function isQuestValidForLevel()
    local currentQuest = lp.CurrentQuest.Value
    if currentQuest == "" then return true end
    local data = getQuestDataForLevel(lp.PlayerStats.lvl.Value)
    if not data then return true end
    return currentQuest == data.questName
end

